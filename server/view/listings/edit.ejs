<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StayNest - Edit Listing</title>
</head>
<body>
    <h3>Edit Listing</h3>
    <form action="/listings/<%= listing._id %>?_method=PUT" method="POST">
        <div>
            <label for="title">Title</label>
            <br>
            <input type="text" name="listing[title]" id="title" value="<%= listing.title %>" required>
        </div>
        <br>
        <div>
            <label for="description">Description</label>
            <br>
            <textarea name="listing[description]" id="description"><%= listing.description %></textarea>
        </div>
        <br>
        <div>
            <label for="image">Image URL</label>
            <br>
            <input type="text" name="listing[image]" id="image" value="<%= listing.image && listing.image.url ? listing.image.url : '' %>">
        </div>
        <br>
        <div>
            <label for="price">Price</label>
            <br>
            <input type="number" name="listing[price]" id="price" value="<%= listing.price %>" min="0">
        </div>
        <br>
        <div>
            <label for="location">Location</label>
            <br>
            <input type="text" name="listing[location]" id="location" value="<%= listing.location %>" required>
        </div>
        <br>
        <div>
            <label for="country">Country</label>
            <br>
            <input type="text" name="listing[country]" id="country" value="<%= listing.country %>" required>
        </div>
        <br>
        <button type="submit">Update Listing</button>
    </form>

    <br><br>
    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
        <button type="submit" style="color: red;">Delete Listing</button>
    </form>

    <br>
    <a href="/listings/<%= listing._id %>">Back to Listing</a>
</body>
</html>
