<% layout('layouts/boilerplate') -%>

<div class="row mt-5">
  <div class="col-6 offset-3">
    <div class="alert alert-danger" role="alert">
      <h4 class="alert-heading">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <%= err.statusCode %> — Error
      </h4>
      <hr>
      <p><%= err.message %></p>
    </div>
  </div>
</div>